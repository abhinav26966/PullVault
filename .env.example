# PullVault — environment reference
#
# Copy to .env.local and fill in values. Never commit .env.local.
# Full reference: ARCHITECTURE.md Appendix B.

# =====================================================================
# Database — Supabase Postgres
# =====================================================================
#
# IMPORTANT: PullVault uses Supabase's pooler URL exclusively (port 6543,
# host pattern *.pooler.supabase.com). The direct connection
# (db.<project>.supabase.co:5432) is IPv6-only on the Supabase free tier
# and is unreachable from many client machines. Both DATABASE_URL and
# DATABASE_POOL_URL hold the same pooler URL; the second name is kept for
# clarity in deploy configs.
#
# The pooler runs PgBouncer in transaction mode. The runtime postgres-js
# client must be configured with `prepare: false` (no prepared statements).
# Get the URL from Supabase: Project Settings → Database → Connection
# string → "Transaction pooler".
DATABASE_URL=postgresql://postgres.<project>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres
DATABASE_POOL_URL=postgresql://postgres.<project>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres

# =====================================================================
# Redis — Upstash
# =====================================================================
#
# Use the rediss:// (TLS) URL from the Upstash console. ioredis is the
# client (not @upstash/redis — we need raw Pub/Sub).
REDIS_URL=rediss://default:<token>@<endpoint>.upstash.io:6379

# =====================================================================
# Auth
# =====================================================================
#
# Generate with: openssl rand -base64 32
# Must be identical between the web app and the WS server.
JWT_SECRET=

# Cookie domain — leave unset for localhost dev; set to apex domain in prod.
# COOKIE_DOMAIN=.pullvault.app

# =====================================================================
# Public URLs (cross-service)
# =====================================================================
#
# WEB_PUBLIC_URL — used by the WS server's CORS allowlist.
# NEXT_PUBLIC_WS_URL — used by the browser to dial the WS server.
WEB_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# =====================================================================
# Price source — Pokemon TCG API
# =====================================================================
#
# PRICE_SOURCE selects the adapter at module load. Default: pokemontcg.
# 'tcgplayer' is a stub that throws "not yet implemented" — do not flip
# unless the TCGplayer adapter is implemented (post Part A only).
PRICE_SOURCE=pokemontcg

# pokemontcg.io API key — optional but strongly recommended.
# Free + instant signup at https://pokemontcg.io. With a key the rate
# limit is 1000 requests/day; without it, ~100/day.
POKEMON_TCG_API_KEY=

# TCGplayer credentials — only set if PRICE_SOURCE=tcgplayer (not in Part A).
# TCGPLAYER_PUBLIC_KEY=
# TCGPLAYER_PRIVATE_KEY=

# =====================================================================
# WS server tuning (apps/ws only)
# =====================================================================
#
# Port the WS server listens on. Railway provides PORT automatically in prod.
PORT=4000

# Real-price refresh cadence. Default 1h.
PRICE_REFRESH_INTERVAL_HOURS=1

# Minimum drift (%) to broadcast a price change. Default 1%.
PRICE_BROADCAST_THRESHOLD_PERCENT=1

# Demo-mode jitter — adds bounded synthetic motion every N seconds for
# video recordings. OFF by default. Do not enable in production.
PRICE_DEMO_MODE=false
PRICE_DEMO_INTERVAL_SECONDS=30
PRICE_DEMO_MAX_DRIFT_PERCENT=2

# =====================================================================
# Card pipeline (initial run + recurring refresh)
# =====================================================================
#
# Comma-separated pokemontcg.io set IDs to seed/refresh from.
SEED_SETS=swsh1,swsh4,swsh12,sv1,sv3

# Soft cap on how many cards to keep per set (after sampling).
SEED_CARDS_PER_SET=100

# =====================================================================
# Part B — drop fairness, sealed auctions, pack economics, provably fair
# =====================================================================
#
# All optional; defaults are fine. Defined here for visibility.
# Cross-reference: ARCHITECTURE.md §10–§14.

# Lottery fairness window after a drop's starts_at. Buy intents enqueue
# into Redis with a random score during this window; a 2s cron drains in
# score order. Default 5s. Set on both the web app (buy route) and the
# ws process (lottery-resolver cron).
LOTTERY_WINDOW_MS=5000

# Sealed-bid window before an auction's ends_at. The auction-closer cron
# flips OPEN → SEALED at ends_at − SEALED_WINDOW_MS; the public WS room
# redacts amount/bidder until settlement. Default 60s. ws-only.
SEALED_WINDOW_MS=60000

# Set to "1" to enable hourly auto-recompute of pack rarity weights on
# the price-refresh cron. Off by default — Part B's /admin/health has a
# manual "Recompute now" button that's preferred at trial scale (clearer
# audit trail). ws-only.
ECONOMICS_AUTO_RECOMPUTE=

# Provably-fair seed pool target size. The refill cron tops the unused
# subset up to this number on boot and hourly. Default 100. ws-only.
SEED_POOL_TARGET=100
